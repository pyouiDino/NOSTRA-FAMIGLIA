rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(uid())).data; }
    function role() { return userDoc().role; }
    function isAdmin() { return role() == 'admin' || role() == 'superadmin'; }
    function isSuperAdmin() { return role() == 'superadmin'; }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAuth() && isSuperAdmin();
    }
    match /zones/{zoneId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /points/{pointId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAuth() && isAdmin();
    }
    match /invite_codes/{code} {
      allow read: if isAuth();
      allow create: if isAuth() && isAdmin();
      allow update: if isAuth();
      allow delete: if isAuth() && isAdmin();
    }
    match /roles/{roleId} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin();
    }
    match /personal_maps/{userId} {
      allow read, write: if isAuth() && (request.auth.uid == userId || isAdmin());
    }
  }
}
